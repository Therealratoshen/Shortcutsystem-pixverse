# PixVerse API Key - Get your key from https://platform.pixverse.ai/
VITE_PIXVERSE_API_KEY=your_api_key_here

# MiniMax API Key - Get your key from https://platform.minimax.chat/
# Used for AI-powered product insights detection with MiniMax M.2.7
VITE_MINIMAX_API_KEY=your_minimax_api_key_here

# API Base URL (leave empty for production, use http://localhost:3001 for local development)
VITE_API_URL=

# GitHub Integration (for API routes)
GITHUB_TOKEN=your_github_token
GITHUB_REPO_OWNER=Therealratoshen
GITHUB_REPO_NAME=Shortcutsistem-pixverse
